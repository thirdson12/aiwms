# Database
DATABASE_URL="postgresql://aiwms:aiwms@localhost:5432/aiwms?schema=public"

# API
API_PORT=3001
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_REFRESH_SECRET="change-me-refresh-secret-use-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000"

# Web
NEXT_PUBLIC_API_URL="http://localhost:3001"
API_URL="http://localhost:3001"

# Render (production — set automatically by render.yaml blueprint)
# DATABASE_URL          → from PostgreSQL service
# JWT_SECRET            → auto-generated
# JWT_REFRESH_SECRET    → auto-generated
# CORS_ORIGIN           → web service URL (API service)
# API_URL               → api service URL (web service)
# PORT                  → set by Render (API listens on this)
